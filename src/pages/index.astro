---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead
			title="Purushotham Reddy | AI/ML Engineer"
			description="Portfolio of Purushotham Reddy - AI/ML Engineer, Full Stack Developer"
		/>
		<!-- Vanilla Tilt JS -->
		<script
			src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"
			integrity="sha512-wC/cunGGDjXSl9OHweO0RuZgO53SXR5oY02MzjtA8iA1t28Gg7jB2L//eAA1njb67i7e36m57XJz2qDq7A8Bw=="
			crossorigin="anonymous"
			referrerpolicy="no-referrer"></script>
	</head>
	<body
		class="antialiased selection:bg-neon-cyan selection:text-space-900 overflow-x-hidden"
	>
		<Header />

		<main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16">
			<!-- HERO SECTION -->
			<section
				id="home"
				class="min-h-[85vh] flex flex-col md:flex-row items-center justify-between gap-12 reveal-on-scroll active"
			>
				<div
					class="flex-1 space-y-8 z-10 w-full mb-12 md:mb-0 text-center md:text-left"
				>
					<div class="space-y-2">
						<p
							class="text-neon-cyan font-mono tracking-widest uppercase text-sm"
						>
							Hello,I'm
						</p>
						<h1
							class="text-5xl md:text-7xl font-bold font-heading bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-400"
						>
							Purushotham Reddy
						</h1>
					</div>
					<div class="h-8 md:h-12 overflow-hidden">
						<h2
							class="text-2xl md:text-3xl font-mono text-gray-300"
						>
							&gt; <span id="typewriter" class="text-neon-violet"
							></span><span class="animate-pulse">_</span>
						</h2>
					</div>
					<p
						class="text-gray-400 max-w-xl text-lg leading-relaxed mx-auto md:mx-0"
					>
						I am a dedicated AI/ML Engineer and Java Full Stack Developer. I believe in writing clean, honest, and simple code. I enjoy blending machine learning models with robust web architectures to build practical and efficient solutions.
					</p>
					<div
						class="flex flex-wrap gap-4 pt-4 justify-center md:justify-start"
					>
						<a
							href="/resume.pdf"
							class="btn-glow border-glow"
							download>Download Resume</a
						>
						<a
							href="#projects"
							class="px-6 py-3 rounded-lg border border-white/20 hover:border-white/40 bg-white/5 hover:bg-white/10 transition-colors text-white font-medium"
							>View Projects</a
						>
					</div>
				</div>
				<div
					class="flex-1 flex justify-center w-full max-w-md relative"
				>
					<!-- Glowing orb behind headshot -->
					<div
						class="absolute inset-0 bg-gradient-to-tr from-neon-cyan/20 to-neon-violet/20 rounded-full blur-3xl rounded-full scale-90 -z-10"
					>
					</div>
					<!-- Headshot container -->
					<div
						class="glass-card p-2 rounded-[2rem] w-64 h-64 md:w-80 md:h-80 relative overflow-hidden transform hover:-translate-y-2 transition-transform duration-500"
					>
						<img
							src="/profile.jpg"
							alt="Purushotham Reddy"
							class="w-full h-full object-cover rounded-[1.8rem] transition-opacity hover:opacity-100 opacity-90"
						/>
					</div>
				</div>
			</section>

			<!-- ABOUT SECTION -->
			<section id="about" class="py-24 reveal-on-scroll">
				<div class="flex flex-col md:flex-row gap-12 items-center">
					<div class="md:w-1/3">
						<h2
							class="text-3xl md:text-5xl font-heading mb-6 relative inline-block"
						>
							Who I Am
							<span
								class="absolute -bottom-2 left-0 w-1/2 h-1 bg-gradient-to-r from-neon-cyan to-transparent rounded-full"
							></span>
						</h2>
					</div>
					<div
						class="md:w-2/3 glass-card p-8 text-gray-300 leading-relaxed font-mono"
					>
						<p class="mb-4">
							I am a 2nd-year B.Tech student at QIS College,
							specializing in <span
								class="text-white font-semibold border-b border-neon-cyan/50 pb-0.5"
								>Artificial Intelligence & Machine Learning</span
							>.
						</p>
						<p class="mb-4">
							Currently maintaining a <span class="text-neon-cyan"
								>CGPA of 9.0/10</span
							>, I am deeply committed to pushing the boundaries
							of what software can achieve through intelligent
							algorithms.
						</p>
						<p>
							I am interested in learning and building projects in AI/ML using Python. I focus on improving my programming skills and creating simple, efficient solutions through continuous practice and learning
						</p>
					</div>
				</div>

				<!-- Achievements Snippet -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
					<div
						class="glass-card p-6 border-l-4 border-l-neon-cyan hover:border-l-neon-violet transition-colors flex items-center gap-4"
					>
						<div
							class="p-3 bg-neon-cyan/10 rounded-lg text-neon-cyan"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-award"
								><circle cx="12" cy="8" r="6"></circle><path
									d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"
								></path></svg
							>
						</div>
						<div>
							<h4 class="font-heading text-white">
								Academic Excellence
							</h4>
							<p class="font-mono text-sm text-gray-400">
								97.4% in Intermediate
							</p>
						</div>
					</div>
					<div
						class="glass-card p-6 border-l-4 border-l-neon-violet hover:border-l-neon-cyan transition-colors flex items-center gap-4"
					>
						<div
							class="p-3 bg-neon-violet/10 rounded-lg text-neon-violet"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-file-badge"
								><path
									d="M12 22h6a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v3"
								></path><path d="M14 2v4a2 2 0 0 0 2 2h4"
								></path><path
									d="M5 17a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"
								></path><path d="M7 16.5 8 22l-3-1-3 1 1-5.5"
								></path></svg
							>
						</div>
						<div>
							<h4 class="font-heading text-white">
								Certified Professional
							</h4>
							<p class="font-mono text-sm text-gray-400">
								5+ Certifications Achieved
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- SKILLS MATRIX -->
			<section id="skills" class="py-24 reveal-on-scroll">
				<div class="mb-16">
					<h2
						class="text-3xl md:text-5xl font-heading mb-4 text-center"
					>
						Skills
					</h2>
					<p
						class="text-gray-400 text-center font-mono max-w-2xl mx-auto"
					>
						Core competencies across the stack
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<!-- Intelligence -->
					<div
						class="glass-card p-8 group hover:-translate-y-2 transition-all duration-300 pulse-glow"
					>
						<div
							class="w-12 h-12 bg-neon-cyan/20 rounded-xl flex items-center justify-center mb-6 text-neon-cyan group-hover:scale-110 transition-transform shadow-[0_0_15px_rgba(0,243,255,0.2)]"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-brain-circuit"
								><path
									d="M12 4.5a2.5 2.5 0 0 0-4.96-.46 2.5 2.5 0 0 0-1.98 3 2.5 2.5 0 0 0-1.32 4.24 3 3 0 0 0 .34 5.58 2.5 2.5 0 0 0 2.96 3.08 2.5 2.5 0 0 0 4.91.05L12 20V4.5Z"
								></path><path d="M16 8V5c0-1.1.9-2 2-2"
								></path><path d="M12 13h4"></path><path
									d="M12 18h6a2 2 0 0 1 2 2v1"></path><path
									d="M19 15v-3"></path></svg
							>
						</div>
						<h3 class="text-xl font-heading text-white mb-4">
							Intelligence
						</h3>
						<ul class="space-y-3 font-mono text-sm text-gray-300">
							<li class="flex items-center gap-2">
								<span
									class="w-1.5 h-1.5 rounded-full bg-neon-cyan"
								></span> Numpy
							</li>
							<li class="flex items-center gap-2">
								<span
									class="w-1.5 h-1.5 rounded-full bg-neon-cyan"
								></span> Pandas
							</li>
							<li class="flex items-center gap-2">
								<span
									class="w-1.5 h-1.5 rounded-full bg-neon-cyan"
								></span> Computer Vision
							</li>
							<li class="flex items-center gap-2">
								<span
									class="w-1.5 h-1.5 rounded-full bg-neon-cyan"
								></span> Artificial Intelligence
							</li>
						</ul>
					</div>

					<!-- Development -->
					<div
						class="glass-card p-8 group hover:-translate-y-2 transition-all duration-300 pulse-glow"
					>
						<div
							class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mb-6 text-white group-hover:scale-110 transition-transform shadow-[0_0_15px_rgba(255,255,255,0.1)]"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-code-2"
								><path d="m18 16 4-4-4-4"></path><path
									d="m6 8-4 4 4 4"></path><path
									d="m14.5 4-5 16"></path></svg
							>
						</div>
						<h3 class="text-xl font-heading text-white mb-4">
							Development
						</h3>
						<ul class="space-y-3 font-mono text-sm text-gray-300">
							<li class="flex items-center gap-2">
								<span class="w-1.5 h-1.5 rounded-full bg-white"
								></span> Python
							</li>
							<li class="flex items-center gap-2">
								<span class="w-1.5 h-1.5 rounded-full bg-white"
								></span> Java
							</li>
							<li class="flex items-center gap-2">
								<span class="w-1.5 h-1.5 rounded-full bg-white"
								></span> Android / Kotlin
							</li>
							<li class="flex items-center gap-2">
								<span class="w-1.5 h-1.5 rounded-full bg-white"
								></span> HTML / CSS
							</li>
							<li class="flex items-center gap-2">
								<span class="w-1.5 h-1.5 rounded-full bg-white"
								></span> SQL
							</li>
						</ul>
					</div>

					<!-- Tools -->
					<div
						class="glass-card p-8 group hover:-translate-y-2 transition-all duration-300 pulse-glow"
					>
						<div
							class="w-12 h-12 bg-neon-violet/20 rounded-xl flex items-center justify-center mb-6 text-neon-violet group-hover:scale-110 transition-transform shadow-[0_0_15px_rgba(138,43,226,0.2)]"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-wrench"
								><path
									d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
								></path></svg
							>
						</div>
						<h3 class="text-xl font-heading text-white mb-4">
							Tools
						</h3>
						<ul class="space-y-3 font-mono text-sm text-gray-300">
							<li class="flex items-center gap-2">
								<span
									class="w-1.5 h-1.5 rounded-full bg-neon-violet"
								></span> Git & GitHub
							</li>
							<li class="flex items-center gap-2">
								<span
									class="w-1.5 h-1.5 rounded-full bg-neon-violet"
								></span> VS Code
							</li>
							<li class="flex items-center gap-2">
								<span
									class="w-1.5 h-1.5 rounded-full bg-neon-violet"
								></span> Google Colab
							</li>
						</ul>
					</div>
				</div>
			</section>

			<!-- PROJECTS GALLERY -->
			<section id="projects" class="py-24 reveal-on-scroll">
				<div
					class="mb-16 flex flex-col md:flex-row justify-between items-end gap-4 border-b border-white/10 pb-4"
				>
					<div>
						<h2
							class="text-3xl md:text-5xl font-heading mb-2 text-white"
						>
							 Projects
						</h2>
						<p class="text-gray-400 font-mono">
							Building systems that learn and adapt.
						</p>
					</div>
					<a
						href="https://github.com/purushotham1599-creator"
						target="_blank"
						class="text-neon-cyan hover:text-white transition-colors font-mono whitespace-nowrap flex items-center gap-2"
					>
						View +4 Projects <svg
							xmlns="http://www.w3.org/2000/svg"
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="lucide lucide-arrow-right"
							><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
							></path></svg
						>
					</a>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full max-w-6xl mx-auto">
					<!-- Project 1 -->
					<div
						class="glass-card overflow-hidden group relative flex flex-col p-8"
						data-tilt
						data-tilt-max="3"
						data-tilt-speed="400"
						data-tilt-glare
						data-tilt-max-glare="0.1"
					>
						<div class="absolute inset-0 bg-gradient-to-br from-neon-cyan/5 to-transparent z-0"></div>
						<div class="relative z-10 flex flex-col h-full">
							<h3 class="text-2xl font-heading text-white mb-4">Image Captioning Project</h3>
							<p class="text-gray-400 mb-6 leading-relaxed flex-grow text-sm">
								An advanced deep learning model that automatically converts image features into natural language descriptions. It combines a Vision Transformer (ViT) for extracting meaningful visual features from images and a Transformer-based language model (GPT-2) to generate sequential, context-aware text captions using self-attention mechanisms.
							<a
								href="https://github.com/purushotham1599-creator/Image-Captioning-Project"
								target="_blank"
								class="inline-flex items-center gap-2 text-white hover:text-neon-cyan transition-colors border border-white/20 hover:border-glow rounded-lg px-4 py-2 font-mono text-xs w-max"
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.5-1.4 6.5-7a4.6 4.6 0 0 0-1.4-3.6 4.3 4.3 0 0 0-.1-3.5s-1.1-.3-3.5 1.4a11.4 11.4 0 0 0-6 0C6.1 1.6 5 1.9 5 1.9a4.3 4.3 0 0 0-.1 3.5 4.6 4.6 0 0 0-1.4 3.6c0 5.6 3.3 6.6 6.5 7a4.8 4.8 0 0 0-1 3.02v4"></path><path d="M9 20c-5 1.5-5-2.5-7-3"></path></svg> Source Code
							</a>
						</div>
					</div>

					<!-- Project 2 -->
					<div
						class="glass-card overflow-hidden group relative flex flex-col p-8"
						data-tilt
						data-tilt-max="3"
						data-tilt-speed="400"
						data-tilt-glare
						data-tilt-max-glare="0.1"
					>
						<div class="absolute inset-0 bg-gradient-to-br from-neon-violet/5 to-transparent z-0"></div>
						<div class="relative z-10 flex flex-col h-full">
							<h3 class="text-2xl font-heading text-white mb-4">PhishGuard</h3>
							<p class="text-gray-400 mb-6 leading-relaxed flex-grow text-sm">
								A sophisticated cybersecurity tool designed to detect, analyze, and prevent phishing attacks, leveraging real-time URL scanning and intelligent threat detection algorithms.
							</p>
							<a
								href="https://github.com/purushotham1599-creator/PhishGuard"
								target="_blank"
								class="inline-flex items-center gap-2 text-white hover:text-neon-violet transition-colors border border-white/20 hover:border-neon-violet/50 rounded-lg px-4 py-2 font-mono text-xs w-max"
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.5-1.4 6.5-7a4.6 4.6 0 0 0-1.4-3.6 4.3 4.3 0 0 0-.1-3.5s-1.1-.3-3.5 1.4a11.4 11.4 0 0 0-6 0C6.1 1.6 5 1.9 5 1.9a4.3 4.3 0 0 0-.1 3.5 4.6 4.6 0 0 0-1.4 3.6c0 5.6 3.3 6.6 6.5 7a4.8 4.8 0 0 0-1 3.02v4"></path><path d="M9 20c-5 1.5-5-2.5-7-3"></path></svg> Source Code
							</a>
						</div>
					</div>

					<!-- Project 3 -->
					<div
						class="glass-card overflow-hidden group relative flex flex-col p-8"
						data-tilt
						data-tilt-max="3"
						data-tilt-speed="400"
						data-tilt-glare
						data-tilt-max-glare="0.1"
					>
						<div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent z-0"></div>
						<div class="relative z-10 flex flex-col h-full">
							<h3 class="text-2xl font-heading text-white mb-4">Market Website</h3>
							<p class="text-gray-400 mb-6 leading-relaxed flex-grow text-sm">
								A fully responsive, intuitive e-commerce marketplace platform built with modern web technologies to handle product listings, transactions, and user interactions flawlessly.
							</p>
							<a
								href="https://github.com/purushotham1599-creator/Market-Website"
								target="_blank"
								class="inline-flex items-center gap-2 text-white hover:text-white transition-colors border border-white/20 hover:border-white/50 rounded-lg px-4 py-2 font-mono text-xs w-max"
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.5-1.4 6.5-7a4.6 4.6 0 0 0-1.4-3.6 4.3 4.3 0 0 0-.1-3.5s-1.1-.3-3.5 1.4a11.4 11.4 0 0 0-6 0C6.1 1.6 5 1.9 5 1.9a4.3 4.3 0 0 0-.1 3.5 4.6 4.6 0 0 0-1.4 3.6c0 5.6 3.3 6.6 6.5 7a4.8 4.8 0 0 0-1 3.02v4"></path><path d="M9 20c-5 1.5-5-2.5-7-3"></path></svg> Source Code
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- EXPERIENCE & CERTIFICATIONS -->
			<section id="experience" class="py-24 reveal-on-scroll">
				<h2 class="text-3xl md:text-5xl font-heading mb-16 text-center">
					Journey & Work History
				</h2>

				<div
					class="grid grid-cols-1 md:grid-cols-2 gap-12 relative max-w-4xl mx-auto"
				>
					<!-- Connecting line -->
					<div
						class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-gradient-to-b from-neon-cyan via-neon-violet to-transparent -translate-x-1/2"
					>
					</div>

					<!-- Item -->
					<div class="md:pr-12 md:text-right relative">
						<div
							class="hidden md:block absolute right-0 top-6 w-3 h-3 bg-neon-cyan rounded-full translate-x-1.5 shadow-[0_0_10px_#00f3ff]"
						>
						</div>
						<div
							class="glass-card p-6 border-b-2 border-b-neon-cyan inline-block w-full"
						>
							<span
								class="text-neon-cyan font-mono text-sm block mb-1"
								>Innolance</span
							>
							<h3 class="text-xl font-heading text-white mb-2">
								Machine Learning Workshop
