---
const today = new Date();
---

<footer class="mt-20 border-t border-white/10 glass-card mx-auto max-w-6xl rounded-t-3xl py-12 px-6 lg:px-8 mb-0 pb-8 text-center text-gray-400">
	<div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-left mb-8">
		<div>
			<h3 class="text-xl font-heading text-white mb-4">Say Hello</h3>
			<p class="text-sm mb-6 max-w-sm">
				Feel free to reach out for collaborations or just a friendly hello. Let's build something cool together.
			</p>
			<!-- Simple simulated functional form -->
			<form class="space-y-4" action="#" method="POST" onsubmit="event.preventDefault(); alert('Message form is UI only right now!');">
				<input type="email" placeholder="Your email address" class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-neon-cyan focus:ring-1 focus:ring-neon-cyan transition-colors" required>
				<button type="submit" class="btn-glow w-full sm:w-auto">Send Message</button>
			</form>
		</div>
		<div class="flex flex-col md:items-end md:justify-center">
			<h3 class="text-xl font-heading text-white mb-4">Connect</h3>
			<div class="flex gap-4">
				<a href="https://linkedin.com/in/purushotham-reddy-44b1a9337/" target="_blank" class="w-10 h-10 rounded-full glass-card flex items-center justify-center hover:text-neon-cyan transition-colors">
					<span class="sr-only">LinkedIn</span>
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
				</a>
				<a href="https://github.com/purushotham1599-creator" target="_blank" class="w-10 h-10 rounded-full glass-card flex items-center justify-center hover:text-neon-cyan transition-colors">
					<span class="sr-only">GitHub</span>
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.5-1.4 6.5-7a4.6 4.6 0 0 0-1.4-3.6 4.3 4.3 0 0 0-.1-3.5s-1.1-.3-3.5 1.4a11.4 11.4 0 0 0-6 0C6.1 1.6 5 1.9 5 1.9a4.3 4.3 0 0 0-.1 3.5 4.6 4.6 0 0 0-1.4 3.6c0 5.6 3.3 6.6 6.5 7a4.8 4.8 0 0 0-1 3.02v4"/><path d="M9 20c-5 1.5-5-2.5-7-3"/></svg>
				</a>
				<a href="mailto:contact@example.com" class="w-10 h-10 rounded-full glass-card flex items-center justify-center hover:text-neon-cyan transition-colors">
					<span class="sr-only">Email</span>
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
				</a>
			</div>
		</div>
	</div>
	
	<div class="pt-8 border-t border-white/5 text-sm">
		&copy; {today.getFullYear()} Purushotham Reddy. Engineered with Astro & Tailwind.
	</div>
</footer>
